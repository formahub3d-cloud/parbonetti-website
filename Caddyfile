{
	# Railway gestisce HTTPS/certificati a monte: niente cert da Caddy
	auto_https off
	admin off
}

# Railway inietta la variabile PORT; in locale usa 80
:{$PORT:80} {
	root * /srv
	encode gzip
	file_server

	# URL pulite: /contatti serve contatti.html
	try_files {path} {path}.html {path}/

	# Header di sicurezza di base
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
