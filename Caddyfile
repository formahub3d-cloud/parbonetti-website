{
	# Railway gestisce HTTPS/certificati a monte: niente cert da Caddy
	auto_https off
	admin off
}

# Railway inietta la variabile PORT; in locale usa 80
:{$PORT:80} {
	root * /srv
	encode gzip
	file_server

	# URL pulite: /contatti serve contatti.html
	try_files {path} {path}.html {path}/

	# Header di sicurezza
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		# CSP: consente font Google, embed YouTube e Google Maps, e gli script/stili inline del sito.
		# NB: se in futuro il form punta a Formspree/EmailJS, aggiungere il dominio in connect-src/form-action.
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://www.google.com; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'self'"
		-Server
	}

	# Cache: immagini/font in cache una settimana; HTML/CSS/JS sempre rivalidati
	# (così ogni aggiornamento del sito è subito visibile, niente versioni vecchie in cache).
	@cacheable path *.jpg *.jpeg *.png *.webp *.svg *.ico *.gif *.woff *.woff2
	header @cacheable Cache-Control "public, max-age=604800"
	@nocache {
		not path *.jpg *.jpeg *.png *.webp *.svg *.ico *.gif *.woff *.woff2
	}
	header @nocache Cache-Control "no-cache"
}
